def read_notes():
    with open ("notes.txt","r") as file:
        content=file.read()
        if content:
            print("NOTES")
            print(content.title())
        else:
            print("You have no notes yet.")

def add_notes():
        notes=input("Enter your note:")
        with open ("notes.txt","a") as file:
            file.write("\n"+ notes +"\n")
        print("Note added")

def clear_notes():
    with open ("notes.txt","w") as  file:
        pass
    print("Notes cleared")

def change_textfont(text):
    font=input("Pick a font: 1.Bold   2.Cursive")

    fancy = "𝓪𝓫𝓬𝓭𝓮𝓯𝓰𝓱𝓲𝓳𝓴𝓵𝓶𝓷𝓸𝓹𝓺𝓻𝓼𝓽𝓾𝓿𝔀𝔁𝔂𝔃!"
    bold="𝗮𝗯𝗰𝗱𝗲𝗳𝗴𝗵𝗶𝗷𝗸𝗹𝗺𝗻𝗼𝗽𝗾𝗿𝘀𝘁𝘂𝘃𝘄𝘅𝘆𝘇"
    normal = "abcdefghijklmnopqrstuvwxyz"

    result=""


    for char in text:
        if char.lower() in normal:
            index=normal.index(char.lower())
            
            if font=="1":
                result+=bold[index]
            elif font=="2":
                result+=fancy[index]
            elif font=="":
                print("You have exited font selection")
            else:
                result += char
        else:
            result +=char

    return result


while True:
    print("\n ...Notes...")
    print("Press:")
    print("1.Add notes")
    print("2.Delete notes")
    print("3.Show notes")

    choice=input("Pick one:")
    if choice=="1":
        add_notes()
    elif choice=="2":
        clear_notes()
    elif choice=="3":
        read_notes()
    else:
        print("Please select one")
